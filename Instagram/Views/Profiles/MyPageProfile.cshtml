@model InstagramUser
@{
    ViewData["Title"] = Model?.UserName ?? "Profile";
    var displayName = Model?.Name ?? Model?.UserName ?? "Profile";
    var photoSrc = string.IsNullOrWhiteSpace(Model?.Photo)
        ? "https://www.kindpng.com/picc/m/24-248253_user-profile-default-image-png-clipart-png-download.png"
        : Url.Content("~/Uploads/" + Model.Photo.Trim());
}

<div class="ig-profile ig-main--wide mx-auto">
    <header class="ig-profile__header">
        <div class="ig-profile__avatar-wrap">
            <img src="@photoSrc" alt="" class="ig-profile__avatar" width="150" height="150" />
        </div>
        <div class="ig-profile__info">
            <div class="ig-profile__row">
                <h1 class="ig-profile__username">@Model.UserName</h1>
                <button type="button" class="ig-btn ig-btn--outline" data-toggle="modal" data-target="#EditProfilo">Edit profile</button>
                <button type="button" class="ig-btn ig-btn--icon" data-toggle="modal" data-target="#EditProfilo" aria-label="Settings">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                        <path d="M8 4.754a3.246 3.246 0 1 0 0 6.492 3.246 3.246 0 0 0 0-6.492zM5.754 8a2.246 2.246 0 1 1 4.492 0 2.246 2.246 0 0 1-4.492 0z" />
                        <path d="M9.796 1.343c-.527-1.79-3.065-1.79-3.592 0l-.094.319a.873.873 0 0 1-1.255.52l-.292-.16c-1.64-.892-3.433.902-2.54 2.541l.159.292a.873.873 0 0 1-.52 1.255l-.319.094c-1.79.527-1.79 3.065 0 3.592l.319.094a.873.873 0 0 1 .52 1.255l-.16.292c-.892 1.64.901 3.434 2.541 2.54l.292-.159a.873.873 0 0 1 1.255.52l.094.319c.527 1.79 3.065 1.79 3.592 0l.094-.319a.873.873 0 0 1 1.255-.52l.292.16c1.64.893 3.434-.902 2.54-2.541l-.159-.292a.873.873 0 0 1 .52-1.255l.319-.094c1.79-.527 1.79-3.065 0-3.592l-.319-.094a.873.873 0 0 1-.52-1.255l.16-.292c.893-1.64-.902-3.433-2.541-2.54l-.292.159a.873.873 0 0 1-1.255-.52l-.094-.319z" />
                    </svg>
                </button>
            </div>

            <div class="ig-profile__stats">
                <span class="ig-profile__stat"><strong>0</strong> posts</span>
                <a href="#" class="ig-profile__stat"><strong>0</strong> followers</a>
                <a href="#" class="ig-profile__stat"><strong>0</strong> following</a>
            </div>

            <div>
                <p class="ig-profile__bio-name">@displayName</p>
                <p class="ig-profile__bio-text">@Model.Bio</p>
            </div>
        </div>
    </header>

    <ul class="nav ig-tabs border-0 justify-content-center" id="profile-main-tabs" role="tablist">
        <li class="nav-item">
            <a class="nav-link ig-tabs__btn ig-tabs__btn--active active" id="tab-posts-link" data-toggle="tab" href="#tab-pane-posts" role="tab" aria-controls="tab-pane-posts" aria-selected="true">
                <svg aria-hidden="true" fill="currentColor" height="12" viewBox="0 0 24 24" width="12"><path d="M3 3v8h8V3H3zm10 0v8h8V3h-8zM3 13v8h8v-8H3zm10 0v8h8v-8h-8z" /></svg>
                POSTS
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link ig-tabs__btn" id="tab-reels-link" data-toggle="tab" href="#tab-pane-reels" role="tab">
                <svg aria-hidden="true" fill="currentColor" height="12" viewBox="0 0 24 24" width="12"><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z" /></svg>
                REELS
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link ig-tabs__btn" id="tab-tagged-link" data-toggle="tab" href="#tab-pane-tagged" role="tab">
                <svg aria-hidden="true" fill="currentColor" height="12" viewBox="0 0 24 24" width="12"><path d="M10.201 3.797 12 1.997l1.799 1.8a1.905 1.905 0 0 0 2.7 0l1.8-1.8 1.8 1.8a1.905 1.905 0 0 0 2.7 0L22 1.997l1.799 1.8a1.905 1.905 0 0 0 2.7 0l1.8-1.8-.001 3.398a4.95 4.95 0 0 0-1.433 3.548c0 1.922.87 3.637 2.227 4.805L24.997 24H11.998l-2.576-2.576A4.95 4.95 0 0 0 7 19.947c0-1.92.87-3.637 2.227-4.805L1.003 7.497l1.8-1.8a1.905 1.905 0 0 0 0-2.7l-1.8-1.8 1.8-1.8a1.905 1.905 0 0 0 0-2.7L10.201 3.797z" /></svg>
                TAGGED
            </a>
        </li>
    </ul>

    <div class="tab-content pt-3">
        <div class="tab-pane fade show active" id="tab-pane-posts" role="tabpanel" aria-labelledby="tab-posts-link">
            <div class="ig-grid">
                <button type="button" class="ig-grid__cell ig-grid__cell--cta border-0 w-100 p-0 bg-transparent" data-toggle="modal" data-target="#staticBackdrop">
                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                        <path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4z" />
                    </svg>
                    <span>New</span>
                </button>
                @for (var i = 0; i < 8; i++)
                {
                    <div class="ig-grid__cell"></div>
                }
            </div>
            <p class="ig-empty-hint d-none">No Posts Yet</p>
        </div>
        <div class="tab-pane fade" id="tab-pane-reels" role="tabpanel">
            <p class="text-center text-muted py-5">No reels yet.</p>
        </div>
        <div class="tab-pane fade" id="tab-pane-tagged" role="tabpanel">
            <p class="text-center text-muted py-5">No tagged posts yet.</p>
        </div>
    </div>
</div>

<!-- Edit profile modal -->
<div class="modal fade" id="EditProfilo" tabindex="-1" role="dialog" aria-labelledby="editProfileTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title w-100 text-center" id="editProfileTitle">Edit profile</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body pt-2">
                <ul class="nav nav-pills nav-justify mb-3" role="tablist">
                    <li class="nav-item flex-fill text-center">
                        <a class="nav-link active" id="edit-tab-info" data-toggle="pill" href="#edit-pane-info" role="tab">Profile</a>
                    </li>
                    <li class="nav-item flex-fill text-center">
                        <a class="nav-link" id="edit-tab-pass" data-toggle="pill" href="#edit-pane-pass" role="tab">Password</a>
                    </li>
                </ul>
                <div class="tab-content">
                    <div class="tab-pane fade show active" id="edit-pane-info" role="tabpanel" aria-labelledby="edit-tab-info">
                        <form method="post" asp-controller="Profiles" asp-action="EditProfile">
                            @Html.AntiForgeryToken()
                            <div class="form-group">
                                <label for="Name">Name</label>
                                <input class="form-control ig-input" name="Name" id="Name" value="@Model.Name" autocomplete="name" />
                            </div>
                            <div class="form-group">
                                <label for="Bio">Bio</label>
                                <textarea name="Bio" id="Bio" class="form-control ig-input" rows="3">@Model.Bio</textarea>
                            </div>
                            <div class="d-flex justify-content-end">
                                <button type="button" class="btn btn-light border mr-2" data-dismiss="modal">Cancel</button>
                                <button type="submit" class="btn btn-primary" style="background-color: #0095f6; border-color: #0095f6;">Save</button>
                            </div>
                        </form>
                    </div>
                    <div class="tab-pane fade" id="edit-pane-pass" role="tabpanel" aria-labelledby="edit-tab-pass">
                        <div class="form-group">
                            <label for="OldPass">Current password</label>
                            <input class="form-control ig-input" type="password" autocomplete="current-password" id="OldPass" oninput="removeerror(OldPass, TextOldPass)" />
                            <p class="text-danger small" style="display:none" id="TextOldPass">Current password is required</p>
                        </div>
                        <div class="form-group">
                            <label for="NewPass">New password</label>
                            <input class="form-control ig-input" type="password" autocomplete="new-password" id="NewPass" oninput="removeerror(NewPass, TextNewPass)" />
                            <p class="text-danger small" style="display:none" id="TextNewPass">At least 6 characters</p>
                        </div>
                        <div class="form-group">
                            <label for="ConfirmPass">Confirm new password</label>
                            <input class="form-control ig-input" type="password" autocomplete="new-password" id="ConfirmPass" oninput="removeerror(ConfirmPass, TextConfirmPass)" />
                            <p class="text-danger small" style="display:none" id="TextConfirmPass">Passwords do not match</p>
                        </div>
                        <div class="d-flex justify-content-end">
                            <button type="button" id="ChangePassword" class="btn btn-primary" style="background-color: #0095f6; border-color: #0095f6;">Update password</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Create post modal -->
<div class="modal fade" id="staticBackdrop" tabindex="-1" role="dialog" aria-labelledby="createPostTitle" aria-hidden="true" data-backdrop="static">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header align-items-center">
                <h5 class="modal-title w-100 text-center mb-0" id="createPostTitle">Create new post</h5>
                <button type="button" class="close position-absolute" style="right: 1rem;" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="d-flex align-items-center mb-3">
                    <img src="@photoSrc" class="rounded-circle mr-2" width="36" height="36" alt="" style="object-fit: cover;" />
                    <span class="font-weight-bold">@Model.UserName</span>
                </div>
                <textarea class="TextareaCreatePost ig-input border-0 p-0" placeholder="Write a caption..." rows="4" id="desc"></textarea>
                <button type="button" class="btn btn-light border mt-2" id="ChooseImagePostbtn">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16" class="mr-1" aria-hidden="true">
                        <path d="M15 12a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1h1.172a3 3 0 0 0 2.12-.879l.83-.828A1 1 0 0 1 6.827 3h2.344a1 1 0 0 1 .707.293l.828.828A3 3 0 0 0 12.828 5H14a1 1 0 0 1 1 1v6zM2 4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2h-1.172a3 3 0 0 1-1.414-.586l-.828-.828A2 2 0 0 0 9.172 2H6.828a2 2 0 0 0-1.414.586l-.828.828A2 2 0 0 1 3.172 4H2z" />
                    </svg>
                    Add photos
                </button>
                <p class="text-danger small mt-2" style="display:none" id="ExError">Use .png, .jpg, or .jpeg</p>
                <input type="file" id="ChooseImagePost" accept="image/png,image/jpeg,image/jpg" style="display:none" />
            </div>
            <div class="modal-footer border-top-0">
                <button type="button" class="btn btn-light" data-dismiss="modal">Close</button>
                <button type="button" id="upload" class="btn btn-primary" style="background-color: #0095f6; border-color: #0095f6;">Share</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function removeerror(input, p) {
            input.classList.remove("inputError");
            p.style.display = "none";
        }

        $("#ChooseImagePostbtn").on("click", function () {
            document.getElementById("ChooseImagePost").click();
        });

        $("#ChooseImagePost").on("change", function () {
            var input = this;
            if (!input.files || input.files.length === 0) return;
            var ok = true;
            for (var i = 0; i < input.files.length; i++) {
                var n = input.files[i].name.toLowerCase();
                if (n.indexOf(".jpg") <= 0 && n.indexOf(".jpeg") <= 0 && n.indexOf(".png") <= 0) {
                    ok = false;
                    break;
                }
            }
            if (!ok) {
                document.getElementById("ExError").style.display = "block";
                document.getElementById("upload").classList.add("disabled");
            } else {
                document.getElementById("ExError").style.display = "none";
                document.getElementById("upload").classList.remove("disabled");
            }
        });

        $("#upload").on("click", function () {
            if (document.getElementById("upload").classList.contains("disabled")) return;
            var df = new FormData();
            df.append("desc", document.getElementById("desc").value);
            var u = document.getElementById("ChooseImagePost");
            if (u.files) {
                for (var i = 0; i < u.files.length; i++) {
                    df.append("ChooseImagePost", u.files[i]);
                }
            }
            $.ajax({
                url: "/Posts/UploadPost",
                type: "post",
                processData: false,
                contentType: false,
                data: df,
                success: function () {
                    $("#staticBackdrop").modal("hide");
                }
            });
        });

        $("#ChangePassword").on("click", function () {
            var oldP = document.getElementById("OldPass");
            var newP = document.getElementById("NewPass");
            var conf = document.getElementById("ConfirmPass");

            if (!oldP.value.replace(/\s/g, "")) {
                oldP.classList.add("inputError");
                document.getElementById("TextOldPass").style.display = "block";
                return false;
            }
            if (newP.value.length < 6) {
                newP.classList.add("inputError");
                document.getElementById("TextNewPass").style.display = "block";
                return false;
            }
            if (conf.value !== newP.value) {
                conf.classList.add("inputError");
                document.getElementById("TextConfirmPass").style.display = "block";
                return false;
            }

            $.ajax({
                url: "/Profiles/ChangePassword",
                type: "post",
                data: { oldPassword: oldP.value, newPassword: newP.value },
                success: function (result) {
                    if (result === true) {
                        alert("Password updated");
                        $("#EditProfilo").modal("hide");
                    } else {
                        oldP.classList.add("inputError");
                    }
                }
            });
        });
    </script>
}
