@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}

<div class="ig-auth-wrap">
    <div class="ig-form-card" style="max-width: 350px; padding: 32px 40px;">
        <div class="text-center mb-4">
            <img src="~/img/insta.png" alt="Instagram" style="height: 51px; width: auto;" />
        </div>

        <form id="account" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

            <div class="ig-field">
                <input asp-for="Input.EmailOrUserName" class="ig-input" placeholder="Email or username" autocomplete="username" />
                <span asp-validation-for="Input.EmailOrUserName" class="text-danger small d-block mt-1"></span>
            </div>
            <div class="ig-field">
                <input asp-for="Input.Password" class="ig-input" placeholder="Password" autocomplete="current-password" />
                <span asp-validation-for="Input.Password" class="text-danger small d-block mt-1"></span>
            </div>
            <div class="ig-field d-flex align-items-center">
                <label asp-for="Input.RememberMe" class="mb-0 small">
                    <input asp-for="Input.RememberMe" />
                    @Html.DisplayNameFor(m => m.Input.RememberMe)
                </label>
            </div>
            <button type="submit" class="ig-btn ig-btn--primary w-100 mt-2">Log in</button>
        </form>

        <p class="text-center small mt-4 mb-0">
            Don't have an account?
            <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" style="color: var(--ig-link); font-weight: 600;">Sign up</a>
        </p>
    </div>

    <div class="text-center mt-3">
        <img src="~/img/instagramLogo.png" alt="" style="max-width: 180px; opacity: 0.9;" />
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
