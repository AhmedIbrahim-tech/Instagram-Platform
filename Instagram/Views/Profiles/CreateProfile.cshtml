@{
    ViewData["Title"] = "Edit profile";
}

<div class="ig-form-card">
    <h1>Add profile info</h1>
    <p class="text-center text-muted small mb-4">Add a name, bio, and profile photo so friends know it’s you.</p>

    <form method="post" enctype="multipart/form-data" asp-controller="Profiles" asp-action="CreateProfile">
        <div class="ig-field">
            <label for="Name">Name</label>
            <input class="ig-input" name="Name" id="Name" autocomplete="name" required />
        </div>

        <div class="ig-field">
            <label for="Bio">Bio</label>
            <textarea name="Bio" id="Bio" class="ig-input" rows="3" placeholder="Tell people about you"></textarea>
        </div>

        <div class="ig-field text-center">
            <img class="img-Profile border" id="dd" src="https://www.kindpng.com/picc/m/24-248253_user-profile-default-image-png-clipart-png-download.png" alt="" />
            <div class="mt-3">
                <button type="button" class="ig-btn ig-btn--outline" id="ci">Choose profile photo</button>
            </div>
            <input type="file" id="f" name="Photo" accept="image/png,image/jpeg,image/jpg" style="display:none;" />
        </div>

        <button type="submit" class="ig-btn ig-btn--primary w-100 mt-2" id="Sender">Submit</button>
    </form>
</div>

@section Scripts {
    <script>
        $("#ci").on("click", function () {
            document.getElementById("f").click();
        });

        $("#f").on("change", function () {
            var src = document.getElementById("f");
            var target = document.getElementById("dd");
            if (!src.files || !src.files[0]) return;
            var fr = new FileReader();
            fr.readAsDataURL(src.files[0]);
            fr.onload = function () {
                target.src = this.result;
            };
        });

        $("#Sender").on("click", function () {
            var n = document.getElementById("Name");
            if (!n.value.replace(/\s/g, "")) {
                n.classList.add("inputError");
                return false;
            }
        });

        $("#Name").on("input", function () {
            var n = document.getElementById("Name");
            if (n.value.replace(/\s/g, "")) {
                n.classList.remove("inputError");
            }
        });
    </script>
}
